# Public (client-side)
NEXT_PUBLIC_BASE_URL=https://example.com
GOOGLE_SITE_VERIFICATION=replace-with-search-console-token
BING_SITE_VERIFICATION=

# Server-only
# DATA_PROVIDER = rest | firebase
DATA_PROVIDER=rest

# When using REST API, set the base URL for the API
NEXT_PUBLIC_REST_API_BASE_URL=http://localhost:8080/api

# When using Firebase, set the Firebase configuration values
AUTH_COOKIE_NAME=dashboard_session
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=
FIREBASE_STORAGE_BUCKET=
USE_FIREBASE_EMULATOR=true
